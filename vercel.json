{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/youtube-live", "destination": "/api/youtube-live" },
    { "source": "/api/opensky", "destination": "/api/opensky" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://threatnet.world" },
        { "key": "Cache-Control", "value": "s-maxage=30, stale-while-revalidate=10" }
      ]
    }
  ]
}
